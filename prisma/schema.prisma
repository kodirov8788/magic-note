model auctions {
  id                String   @id
  public_identifier String   @unique
  title             String
  description       String?
  starts_at         DateTime @default(now())
  ends_at           DateTime
  created_by        String
  reserve_amount    Int?
  status            String   @default("scheduled")
  created_at        DateTime @default(now())
  updated_at        DateTime

  @@schema("public")
}

model bids {
  id                             String       @id
  public_identifier              String       @unique
  amount                         Int          @default(0)
  terms_agreed                   Boolean      @default(false)
  item_id                        String
  created_by_id                  String
  order_id                       String?      @unique
  created_at                     DateTime     @default(now())
  updated_at                     DateTime
  is_highest_bidder              Boolean      @default(false)
  status                         String       @default("active")
  users                          public_users @relation(fields: [created_by_id], references: [id], onDelete: Cascade)
  items_bids_item_idToitems      items        @relation("bids_item_idToitems", fields: [item_id], references: [id], onDelete: Cascade)
  items_items_final_bid_idTobids items?       @relation("items_final_bid_idTobids")
  orders                         orders?

  @@schema("public")
}

model email_logs {
  id                String         @id
  user_id           String?
  template_id       String?
  email_type        String
  recipient_email   String
  subject           String?
  status            EmailLogStatus
  error_message     String?
  resend_message_id String?
  sent_at           DateTime?
  created_at        DateTime       @default(now())
  users             public_users?  @relation(fields: [user_id], references: [id])

  @@index([created_at])
  @@index([email_type])
  @@index([status])
  @@index([user_id])
  @@schema("public")
}

model email_settings {
  id                          String         @id
  user_id                     String         @unique
  email_notifications_enabled Boolean        @default(true)
  bid_notifications           Boolean        @default(true)
  auction_notifications       Boolean        @default(true)
  marketing_emails            Boolean        @default(false)
  email_frequency             EmailFrequency @default(IMMEDIATE)
  created_at                  DateTime       @default(now())
  updated_at                  DateTime
  users                       public_users   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@schema("public")
}

model email_templates {
  id          String            @id
  template_id String            @unique
  name        String
  description String?
  type        EmailTemplateType
  subject     String
  is_active   Boolean           @default(true)
  created_at  DateTime          @default(now())
  updated_at  DateTime

  @@schema("public")
}

model items {
  id                            String         @id
  public_identifier             String         @unique
  title                         String
  description                   String?
  category                      String
  condition                     ItemCondition  @default(NEW)
  starting_price                Int            @default(0)
  min_bid_increment             Int            @default(1)
  current_bid_amount            Int            @default(0)
  image_paths                   String[]
  start_date                    DateTime       @default(now())
  end_date                      DateTime
  auction_status                AuctionStatus  @default(ACTIVE)
  shipping_payer                ShippingPayer  @default(BUYER)
  shipping_fee                  Int            @default(0)
  shipping_estimated_delivery   String?
  service_fee                   Int            @default(0)
  seller_id                     String
  final_bid_id                  String?        @unique
  order_number                  String?
  created_at                    DateTime       @default(now())
  updated_at                    DateTime
  bids_bids_item_idToitems      bids[]         @relation("bids_item_idToitems")
  bids_items_final_bid_idTobids bids?          @relation("items_final_bid_idTobids", fields: [final_bid_id], references: [id])
  users_items_seller_idTousers  public_users   @relation("items_seller_idTousers", fields: [seller_id], references: [id], onDelete: Cascade)
  orders                        orders[]
  reviews                       reviews[]
  users_UserFavorites           public_users[] @relation("UserFavorites")

  @@schema("public")
}

model notifications {
  id                String               @id
  public_identifier String               @unique
  user_id           String
  payload           Json                 @default("{}")
  is_read           Boolean              @default(false)
  created_at        DateTime             @default(now())
  updated_at        DateTime
  expires_at        DateTime?
  priority          NotificationPriority @default(LOW)
  type              NotificationType
  users             public_users         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([expires_at])
  @@index([priority])
  @@index([type])
  @@index([user_id, created_at])
  @@index([user_id, is_read])
  @@index([user_id, priority])
  @@schema("public")
}

model orders {
  id                String       @id
  public_identifier String       @unique
  order_number      String       @unique
  status            OrderStatus  @default(PAYMENT_PENDING)
  item_price        Int
  shipping_fee      Int
  service_fee       Int
  total_amount      Int
  paid_at           DateTime?
  shipped_at        DateTime?
  delivered_at      DateTime?
  item_id           String
  buyer_id          String
  winning_bid_id    String       @unique
  created_at        DateTime     @default(now())
  updated_at        DateTime
  users             public_users @relation(fields: [buyer_id], references: [id])
  items             items        @relation(fields: [item_id], references: [id])
  bids              bids         @relation(fields: [winning_bid_id], references: [id])
  payments          payments?
  tracking          tracking?

  @@schema("public")
}

model payments {
  id                   String        @id
  public_identifier    String        @unique
  payment_intent_id    String        @unique
  checkout_session_id  String        @unique
  status               PaymentStatus @default(REQUIRES_PAYMENT_METHOD)
  amount               Int
  currency             String        @default("JPY")
  customer_id          String?
  payment_method       String?
  last_four            String?
  receipt_url          String?
  payment_succeeded_at DateTime?
  order_id             String        @unique
  buyer_id             String
  created_at           DateTime      @default(now())
  updated_at           DateTime
  users                public_users  @relation(fields: [buyer_id], references: [id])
  orders               orders        @relation(fields: [order_id], references: [id])

  @@schema("public")
}

model reviews {
  id                                    String       @id
  public_identifier                     String       @unique
  rating                                Int          @db.SmallInt
  title                                 String       @db.VarChar(200)
  comment                               String
  review_type                           ReviewType
  item_condition                        Int?         @db.SmallInt
  shipping_speed                        Int?         @db.SmallInt
  value_for_money                       Int?         @db.SmallInt
  payment_speed                         Int?         @db.SmallInt
  would_sell_again                      Boolean?
  item_id                               String
  reviewer_id                           String
  reviewed_user_id                      String
  created_at                            DateTime     @default(now())
  updated_at                            DateTime
  items                                 items        @relation(fields: [item_id], references: [id], onDelete: Cascade)
  users_reviews_reviewed_user_idTousers public_users @relation("reviews_reviewed_user_idTousers", fields: [reviewed_user_id], references: [id], onDelete: Cascade)
  users_reviews_reviewer_idTousers      public_users @relation("reviews_reviewer_idTousers", fields: [reviewer_id], references: [id], onDelete: Cascade)

  @@schema("public")
}

model seller_profiles {
  id                String       @id
  user_id           String       @unique
  public_identifier String       @unique
  shop_name         String
  bio               String?
  email             String
  phone_number      String?
  avatar_path       String?
  country           String       @default("JP")
  address1          String
  address2          String?
  city              String
  prefecture        String
  zip_code          String
  terms_agreed      Boolean      @default(false)
  privacy_agreed    Boolean      @default(false)
  created_at        DateTime     @default(now())
  updated_at        DateTime
  users             public_users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@schema("public")
}

model tracking {
  orderId            String    @id
  public_identifier  String    @unique
  tracking_number    String
  carrier            Carrier
  shipping_date      DateTime?
  estimated_delivery DateTime?
  additional_notes   String?
  created_at         DateTime  @default(now())
  updated_at         DateTime
  orders             orders    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model public_users {
  id                                      String           @id
  public_identifier                       String           @unique
  email                                   String           @unique
  username                                String           @unique
  role                                    UserRole         @default(BIDDER)
  first_name                              String?
  last_name                               String?
  phone_number                            String?
  country                                 String           @default("JP")
  address1                                String?
  address2                                String?
  city                                    String?
  prefecture                              String?
  zip_code                                String?
  is_active                               Boolean          @default(true)
  is_superuser                            Boolean          @default(false)
  is_staff                                Boolean          @default(false)
  public_metadata                         Json             @default("{}")
  created_at                              DateTime         @default(now())
  updated_at                              DateTime
  avatar_url                              String?
  full_name                               String?
  requested_role                          UserRole?
  status                                  String           @default("ACTIVE")
  supabase_user_id                        String?          @unique
  bids                                    bids[]
  email_logs                              email_logs[]
  email_settings                          email_settings?
  items_items_seller_idTousers            items[]          @relation("items_seller_idTousers")
  notifications                           notifications[]
  orders                                  orders[]
  payments                                payments[]
  reviews_reviews_reviewed_user_idTousers reviews[]        @relation("reviews_reviewed_user_idTousers")
  reviews_reviews_reviewer_idTousers      reviews[]        @relation("reviews_reviewer_idTousers")
  seller_profiles                         seller_profiles?
  items_UserFavorites                     items[]          @relation("UserFavorites")

  @@map("users")
  @@schema("public")
}

