generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_DATABASE_URL")
  schemas  = ["auth", "public"]
}

model Folder {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  name      String
  createdAt DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?  @default(now()) @map("updated_at") @db.Timestamptz(6)
  users     auth_users @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  notes     Note[]

  @@index([createdAt(sort: Desc)], map: "idx_folders_created_at")
  @@index([userId], map: "idx_folders_user_id")
  @@map("folders")
  @@schema("public")
}

model Note {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  folderId     String?    @map("folder_id") @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  title        String     @default("Untitled Note")
  content      String     @default("")
  contentItems Json?      @default("[]") @map("content_items")
  createdAt    DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?  @default(now()) @map("updated_at") @db.Timestamptz(6)
  folder       Folder?    @relation(fields: [folderId], references: [id], onUpdate: NoAction)
  users        auth_users @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdAt(sort: Desc)], map: "idx_notes_created_at")
  @@index([folderId], map: "idx_notes_folder_id")
  @@index([userId], map: "idx_notes_user_id")
  @@index([contentItems], map: "idx_notes_content_items")
  @@map("notes")
  @@schema("public")
}

